import re
import sqlite3
from datetime import datetime

import gi

gi.require_version("Gtk", "4.0")
gi.require_version("Gdk", "4.0")
from gi.repository import Gdk, GLib, Gtk, Pango

DB_PATH = os.path.expanduser("~/.cache/xfce4/notifyd/log.sqlite")

