{
  "custom/app-launcher": {
    "format": "<span size='16000'>’īā</span>",
    "on-click": "pgrep rofi >/dev/null 2>&1 && killall rofi || ~/.config/rofi/scripts/launcher_t1",
    "tooltip-format": "Application Launcher"
  },
  "custom/dots": {
    "format": "¾░ćÖ"
  },
  "custom/mediaplayer": {
    "format": "{icon} {text}",
    "return-type": "json",
    "max-length": 40,
    "format-icons": {
      "spotify": "<span color='#1ed760'>’å╝</span>",
      "default": "<span color='#7aa2f7'>­¤Ä£</span>"
