{
  "custom/app-launcher": {
    "format": "<span size='16000'>ΎΝΔ</span>",
    "on-click": "pgrep rofi >/dev/null 2>&1 && killall rofi || ~/.config/rofi/scripts/launcher_t1",
    "tooltip-format": "Application Launcher"
  },
  "custom/dots": {
    "format": "≤░Θβ"
  },
  "custom/mediaplayer": {
    "format": "{icon} {text}",
    "return-type": "json",
    "max-length": 40,
    "format-icons": {
      "spotify": "<span color='#1ed760'>ΎΗ╝</span>",
      "default": "<span color='#7aa2f7'>ΏθΟε</span>"
    },
    // "exec": "python ~/.config/waybar/mediaplayer.py --player spotify 2> /dev/null",
    // "on-click": "playerctl -p spotify play-pause",
    // "on-scroll-down": "playerctl -p spotify next",
    // "on-scroll-up": "playerctl -p spotify previous",
    "exec": "python ~/.config/waybar/mediaplayer.py 2> /dev/null",
    "on-click": "playerctl play-pause",
    "on-scroll-down": "playerctl next",
    "on-scroll-up": "playerctl previous",
    "smooth-scrolling-threshold": 1
  },
  "hyprland/workspaces": {
    "format": "<span size='14000'>{icon}</span>",
    "on-click": "activate",
    "all-outputs": true,
    "format-icons": {
      "1": "<span size='10000'>ΎΕΣ</span>",
      "2": "<span size='10000'>ΎΕΣ</span>",
      "3": "<span size='10000'>ΎΕΣ</span>",
      "4": "<span size='10000'>ΎΕΣ</span>",
      "5": "<span size='10000'>ΎΕΣ</span>",
      "6": "<span size='10000'>ΎΕΣ</span>",
      "7": "<span size='10000'>ΎΕΣ</span>",
      "8": "<span size='10000'>ΎΕΣ</span>",
      "9": "<span size='10000'>ΎΕΣ</span>",
      "10": "<span size='l0000'>ΎΕΣ</span>",
      "active": "<span size='10000'>ΎΗΤ</span>"
    },
    "sort-by-number": true
  },
  "clock": {
    "interval": 1,
    "format": "<span size='14000' color='#7aa2f7'>≤░╕Ω</span>  {:%a %d %b %H:%M:%S}",
    "tooltip": false,
    "on-click": "pkill galendae || galendae"
  },
  "group/power": {
    "orientation": "horizontal",
    "modules": ["battery", "power-profiles-daemon"]
  },
  "group/group1": {
    "orientation": "horizontal",
    "modules": ["group/power", "tray"]
  },
  "group/group2": {
    "orientation": "horizontal",
    "modules": ["pulseaudio", "group/group1"]
  },
  "group/group3": {
    "orientation": "horizontal",
    "modules": ["backlight", "group/group2"]
  },
  "network": {
    "interval": 1,
    "format-wifi": "<span size='14000' color='#ffa500'>ΎΑβ</span>  {bandwidthDownBytes}",
    "format-ethernet": "<span size='14000' color='#ffa500'>ΎΑβ</span>  {bandwidthDownBytes}",
    "tooltip": false,
    "format-disconnected": ""
  },
  "backlight": {
    "device": "intel_backlight",
    "format": "{icon} {percent}%",
    "format-icons": [
      "<span color='#ffd700' size='12000'>≤░Δγ</span>",
      "<span color='#ffd700' size='12000'>≤░Δδ</span>",
      "<span color='#ffd700' size='12000'>≤░Δε</span>",
      "<span color='#ffd700' size='12000'>≤░Δζ</span>",
      "<span color='#ffd700' size='12000'>≤░Δη</span>",
      "<span color='#ffd700' size='12000'>≤░Δθ</span>",
      "<span color='#ffd700' size='12000'>≤░Δι</span>"
    ],
    "scroll-step": 5,
    "tooltip-format": "Brightness: {percent}%"
  },
  "pulseaudio": {
    "max-volume": 150,
    "scroll-step": 5,
    "on-click": "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle",
    "on-click-right": "pavucontrol",
    "format": "{icon}  {volume}%",
    "format-bluetooth": "<span size='14000' color='#1e90ff'>ΎΛΥ</span> {volume}%",
    "format-bluetooth-muted": "ΎΣο Muted",
    "format-muted": "ΎΣο Muted",
    "format-icons": {
      "hands-free": "≤░ΜΟ",
      "headphone": "<span color='#f4be49'>ΎΑξ</span>",
      "headset": "Ό╣β",
      "phone": "ΎΓΧ",
      "portable": "ΎΓΧ",
      "car": "ΎΗ╣",
      "default": [
        "<span color='#00ff7f'>ΎΑο</span>",
        "<span color='#00ff00'>ΎΑο</span>",
        "<span color='#7fff00'>ΎΑπ</span>",
        "<span color='#b2ff66'>ΎΑπ</span>",
        "<span color='#ffff66'>ΎΑπ</span>",
        "<span color='#ffc300'>ΎΑρ</span>",
        "<span color='#ff8c00'>ΎΑρ</span>",
        "<span color='#ff5733'>ΎΑρ</span>",
        "<span color='#ff0000'>ΎΑρ</span>"
      ]
    }
  },
  "battery": {
    "full-at": 98,
    "interval": 1,
    "states": {
      "critical": 15,
      "warning": 30,
      "minor": 40,
      "moderate": 60,
      "high": 80,
      "good": 98,
      "excelent": 100
    },
    "format": "<span size='14000'>{icon}</span> {capacity}%",
    "format-full": "<span size='14000' color='#00ff7f'>≤░Β╣</span> {capacity}%",
    "format-charging-critical": "<span size='14000'>≤░λθ</span> {capacity}%",
    "format-charging-warning": "<span size='14000'>≤░ΓΗ</span> {capacity}%",
    "format-charging-minor": "<span size='14000'>≤░ΓΘ</span> {capacity}%",
    "format-charging-moderate": "<span size='14000'>≤░λζ</span> {capacity}%",
    "format-charging-high": "<span size='14000'>≤░λη</span> {capacity}%",
    "format-charging-good": "<span size='14000'>≤░ΓΜ</span> {capacity}%",
    "format-icons": {
      "critical": "≤░ΓΔ",
      "warning": "<span color='#ff5733'>≤░Β║</span>",
      "minor": "<span color='#ffc300'>≤░Β╝</span>",
      "moderate": "<span color='#b2ff66'>≤░Β╛</span>",
      "high": "<span color='#00ff00'>≤░ΓΑ</span>",
      "good": "<span color='#00ff7f'>≤░ΓΓ</span>",
      "excelent": "<span color='#00ff7f'>≤░Β╣</span>"
    }
  },
  "power-profiles-daemon": {
    "format": "<span size='14000' color='#6c77bb'>{icon}</span>",
    // TODO: Remove driver from the tooltip
    "tooltip-format": "Power profile: {profile}\nDriver: {driver}",
    "format-icons": {
      "default": "ΎΕ╡ ",
      "performance": "ΎΕ╡ ",
      "balanced": "ΎΚΟ ",
      "power-saver": "<span size='18000'>≤▒ΙΣ</span>"
    }
  },
  "tray": {
    "icon-size": 21,
    "spacing": 5,
    "reverse-direction": true
  },
  "custom/power-menu": {
    "format": "<span size='14000'>έΠ╗</span>",
    "on-click": "wlogout",
    "tooltip-format": "Power Menu"
  }
}
