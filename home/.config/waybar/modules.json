    "tooltip": false,
    "format-disconnected": ""
  },
  "backlight": {
    "device": "intel_backlight",
    "format": "{icon} {percent}%",
    "format-icons": [
      "<span color='#ffd700' size='10000'>¾░âÜ</span>",
      "<span color='#ffd700' size='10000'>¾░âø</span>",
