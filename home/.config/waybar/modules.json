    "format-icons": {
      "1": "<span size='10000'>’äæ</span>",
      "2": "<span size='10000'>’äæ</span>",
      "3": "<span size='10000'>’äæ</span>",
      "4": "<span size='10000'>’äæ</span>",
      "5": "<span size='10000'>’äæ</span>",
      "6": "<span size='10000'>’äæ</span>",
      "7": "<span size='10000'>’äæ</span>",
      "8": "<span size='10000'>’äæ</span>",
      "9": "<span size='10000'>’äæ</span>",
      "10": "<span size='l0000'>’äæ</span>",
      "active": "<span size='10000'>’åÆ</span>"
